PORT=5000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=fightforge
JWT_SECRET=change-this-to-a-long-random-string
# Comma-separated; include both if you open the app via 127.0.0.1 or localhost.
CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173

# Optional: Firebase Auth (see docs/FIREBASE.md). Single-line JSON of the
# Firebase service account key (Project settings > Service accounts > Generate new private key).
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
