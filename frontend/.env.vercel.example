# Copy these into Vercel → your project → Settings → Environment Variables.
# Vite bakes VITE_* in at build time — redeploy after any change.
#
# IMPORTANT: set VITE_API_BASE for BOTH Production and Preview (PR previews
# use a different *.vercel.app hostname; Preview-only missing → HTTP 405 on POST /api).

VITE_API_BASE=https://your-api-host.example.com
VITE_SHOW_DEMO_ACCOUNTS=false
